    - target: {fileID: 2156251885834186526, guid: a9cec0c50375c3343b2c1a5b8a2d04dc, type: 3}
      propertyPath: m_text
      value: "Welcome, Botanist.\r\n\r\nYour mission is to restore this abandoned
        greenhouse.\r\n\r\n\u2022 Seed energy increases automatically over time.\r\n\u2022
        Strike the Mother Seed to gain extra Seed.\r\n\u2022 Plant in empty pots
        to increase passive generation.\r\n\u2022 Use Crystals to multiply plant
        output.\r\n\u2022 Reach 1,000 Seed to unlock the Crystal Chamber.\n\u2022
        Bronze Trophy (1000 seeds & 500 crystals)\n\u2022 Silver Trophy (5000 seeds
        & 1000 crystals)\n\u2022 Golden Trophy (10,000 seeds & 2000 crystals)\r\n\r\nPress
        OK to begin."
